MODEL_PRIMARY=openai:gpt-4o
MODEL_FALLBACK=openai:gpt-4.1
# Optional — GitHub Copilot (not required if OPENAI_API_KEY is set)
GITHUB_COPILOT_TOKEN=
GITHUB_TOKEN=
OPENAI_API_KEY=
EMBEDDING_MODEL=openai:text-embedding-3-small

# Local Postgres (Homebrew / Postgres.app) — use your macOS username, not "postgres"
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/agent_platform
MEMORY_STORE=inmemory
# Optional — leave blank to run without tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Langfuse Cloud: LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000

CORS_ORIGINS=http://localhost:5173
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_REPO_URL=
DEFAULT_PROJECT_NAME=default
