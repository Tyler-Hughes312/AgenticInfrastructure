MODEL_PRIMARY=copilot:gpt-4o
MODEL_FALLBACK=copilot:gpt-4.1
# Written by: npm run copilot-login -w @agentic/server
GITHUB_COPILOT_OAUTH_TOKEN=
GITHUB_COPILOT_TOKEN=
# Optional — git push/PR only
GITHUB_TOKEN=
# Optional — only if you want openai: models / embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=openai:text-embedding-3-small

# Local Postgres only — never Docker.
# Windows installer (password auth):
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/agent_platform
# macOS Homebrew (peer auth):
#   DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/agent_platform
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/agent_platform
MEMORY_STORE=inmemory

# Enterprise / corp Windows PCs
ENTERPRISE_MODE=true
API_HOST=127.0.0.1
API_PORT=8000
# If antivirus locks the repo folder:
# WORKSPACE_ROOT=C:\Users\YOU\AppData\Local\agentic-platform\workspaces

# Corporate proxy / TLS inspection (optional)
# HTTPS_PROXY=http://proxy.company.com:8080
# HTTP_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1
# NODE_USE_ENV_PROXY=1
# NODE_EXTRA_CA_CERTS=C:\path\to\corp-root-ca.pem

# Optional — leave blank to run without tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Langfuse Cloud: LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_REPO_URL=
DEFAULT_PROJECT_NAME=default
