# Local Fastify (default — no Cognito)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
NEXT_PUBLIC_AUTH_MODE=local

# --- GovCloud (after terraform apply) ---
# Prefer: npm run infra:sync-web-env
# which writes packages/web/.env.local from terraform outputs.
#
# NEXT_PUBLIC_AUTH_MODE=cognito
# NEXT_PUBLIC_API_URL=https://xxxxxxxx.execute-api.us-gov-west-1.amazonaws.com
# NEXT_PUBLIC_WS_URL=wss://yyyyyyyy.execute-api.us-gov-west-1.amazonaws.com/dev
# NEXT_PUBLIC_COGNITO_REGION=us-gov-west-1
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-gov-west-1_XXXXXXXXX
# NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_COGNITO_ISSUER_URL=https://cognito-idp.us-gov-west-1.amazonaws.com/us-gov-west-1_XXXXXXXXX
